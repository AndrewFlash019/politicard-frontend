# Copy to .env.local for local dev, or set these in Netlify for production.
# All vars must be prefixed with REACT_APP_ to be exposed to the CRA build.

# Backend base URL. If unset, both src/services/api.js and src/lib/analytics.js
# fall back to the production Render instance — fine for local dev pointing at
# prod, but set this in any staging/preview environment.
REACT_APP_API_BASE_URL=https://politicard-backend.onrender.com

# Supabase auth. If either is missing the client is disabled and a console
# warning fires at boot; auth falls back to the FastAPI path. Set both in any
# environment where Supabase auth is the intended login mechanism.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Sentry error reporting (optional). If unset, Sentry init is skipped silently.
REACT_APP_SENTRY_DSN=
